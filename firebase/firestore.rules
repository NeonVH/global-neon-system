rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function currentUserDoc() {
      return userDoc(request.auth.uid);
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function hasPermission(permission) {
      return signedIn() &&
        (
          currentUserDoc().data.role == "superadmin" ||
          currentUserDoc().data.permissions[permission] == true
        );
    }

    function isSafeMemberPermissions() {
      return request.resource.data.permissions.canViewAdminPanel != true
        && request.resource.data.permissions.canManageGames != true
        && request.resource.data.permissions.canCreateGame != true
        && request.resource.data.permissions.canEditGame != true
        && request.resource.data.permissions.canDeleteGame != true
        && request.resource.data.permissions.canManageUsers != true
        && request.resource.data.permissions.canBanUsers != true
        && request.resource.data.permissions.canManageVip != true
        && request.resource.data.permissions.canApproveVip != true
        && request.resource.data.permissions.canAdjustCoin != true
        && request.resource.data.permissions.canBroadcastAnnouncement != true
        && request.resource.data.permissions.canSendNotifications != true
        && request.resource.data.permissions.canViewAuditLogs != true
        && request.resource.data.permissions.canManageSettings != true
        && request.resource.data.permissions.canViewReports != true;
    }

    match /users/{uid} {
      allow read: if isSelf(uid) || hasPermission("canManageUsers");
      allow create: if isSelf(uid)
        && request.resource.data.role == "member"
        && request.resource.data.vipLevel == "none"
        && request.resource.data.vipExpiry == null
        && request.resource.data.accountStatus == "active"
        && request.resource.data.coin == 500
        && isSafeMemberPermissions();
      allow update: if isSelf(uid)
        && request.resource.data.role == resource.data.role
        && request.resource.data.permissions == resource.data.permissions
        && request.resource.data.coin == resource.data.coin
        && request.resource.data.vipLevel == resource.data.vipLevel
        && request.resource.data.vipExpiry == resource.data.vipExpiry
        && request.resource.data.accountStatus == resource.data.accountStatus;
      allow delete: if false;
    }

    match /usernames/{username} {
      allow read, write: if false;
    }

    match /games/{gameId} {
      allow read: if true;
      allow write: if false;
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if false;
    }

    match /vip_requests/{requestId} {
      allow read: if signedIn() && (resource.data.uid == request.auth.uid || hasPermission("canManageVip") || hasPermission("canApproveVip"));
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == "pending"
        && request.resource.data.reviewedBy == null;
      allow update, delete: if false;
    }

    match /notifications/{notificationId} {
      allow read: if signedIn() && (resource.data.toUid == request.auth.uid || hasPermission("canSendNotifications"));
      allow create, delete: if false;
      allow update: if signedIn()
        && resource.data.toUid == request.auth.uid
        && request.resource.data.toUid == resource.data.toUid
        && request.resource.data.title == resource.data.title
        && request.resource.data.msg == resource.data.msg
        && request.resource.data.type == resource.data.type
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    match /audit_logs/{logId} {
      allow read: if hasPermission("canViewAuditLogs");
      allow write: if false;
    }

    match /sessions/{sessionId} {
      allow read: if signedIn() && resource.data.uid == request.auth.uid;
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if signedIn() && resource.data.uid == request.auth.uid && request.resource.data.uid == request.auth.uid;
      allow delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    match /reports/{reportId} {
      allow create: if signedIn();
      allow read: if hasPermission("canViewReports");
      allow update, delete: if false;
    }

    match /leaderboards_cache/{cacheId} {
      allow read: if true;
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
